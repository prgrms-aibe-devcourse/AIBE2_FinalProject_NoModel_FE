# Local Development Environment Variables (Copy to .env.local)
# Override any values from .env.development for local development

# API Configuration - Uncomment and modify as needed
# VITE_API_BASE_URL=http://localhost:3000/api
# VITE_ENABLE_API_LOGGING=true

# Authentication (if needed)
# VITE_AUTH_ENABLED=true

# Feature Flags
# VITE_FEATURE_ANALYTICS=false
# VITE_FEATURE_DEBUG=true